# Example environment for the master Compose project.
# Copy to a local untracked file (mode 0600) and fill image digests + secret paths.
# Never commit real secrets.
#
# Topology (VAL-MEMB-003..006): master application + PostgreSQL only.
# Challenges are embedded inside the master container on loopback:
#   Prism              http://127.0.0.1:18080
#   agent-challenge    http://127.0.0.1:18081
# There is NO separate challenge-prism / challenge-* Compose service and NO
# required PRISM_IMAGE_* pin for static challenge services.

COMPOSE_PROJECT_NAME=base-mission-master

# Immutable first-party pins (repository@sha256:<64 hex>).
BASE_MASTER_IMAGE_REPOSITORY=registry.local/base-master
BASE_MASTER_IMAGE_DIGEST=replace_with_64_lowercase_hex
POSTGRES_IMAGE_REPOSITORY=postgres
POSTGRES_IMAGE_DIGEST=20edbde7749f822887a1a022ad526fde0a47d6b2be9a8364433605cf65099416

# Host paths (mode 0600 files / 0700 dirs) for protected secrets and config.
BASE_MASTER_CONFIG=/absolute/path/to/master.yaml
BASE_ADMIN_TOKEN_FILE=/absolute/path/to/admin_token
BASE_POSTGRES_PASSWORD_FILE=/absolute/path/to/postgres_password
# Shared challenge token file (mounted into master for embedded Prism/AC).
PRISM_SHARED_TOKEN_FILE=/absolute/path/to/prism_shared_token

# Host bind for the public master API only (loopback, 3100-3199).
BASE_MASTER_HOST_PORT=3180

BASE_POSTGRES_DB=base
BASE_POSTGRES_USER=base

# Watcher / reconcile stay disabled without challenge-* services (safe default).
# Raise only for emergency dual-run against a separate challenge container.
BASE_MASTER_REGISTRY_RECONCILE_INTERVAL_SECONDS=0
BASE_MASTER_CHALLENGE_WATCHER_INTERVAL_SECONDS=0

# Optional historical pins (NOT required; ignored by install-master topology).
# PRISM_IMAGE_REPOSITORY=
# PRISM_IMAGE_DIGEST=
