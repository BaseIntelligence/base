# Example environment for an independent validator Compose project.
# Copy to a local untracked file (mode 0600). Never commit real secrets.
# Prefer ./install-validator.sh --master-url URL which generates this for you.

COMPOSE_PROJECT_NAME=base-mission-validator

# Immutable validator runtime pin (repository@sha256:<64 hex>).
BASE_VALIDATOR_IMAGE_REPOSITORY=registry.local/base-validator-runtime
BASE_VALIDATOR_IMAGE_DIGEST=replace_with_64_lowercase_hex

# Host paths owned by this validator only.
BASE_VALIDATOR_CONFIG=/absolute/path/to/validator.yaml
# Real directory (not a host symlink with restrictive parents); mounted RO at
# /var/lib/base/identity. Container HOME is /var/lib/base/state (writable volume).
BASE_VALIDATOR_PROTOCOL_IDENTITY=/absolute/path/to/identity
BASE_VALIDATOR_BROKER_TOKEN=/absolute/path/to/broker_token
