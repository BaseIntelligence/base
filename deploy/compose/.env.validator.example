# Example environment for an agent-only validator Compose project.
# Copy to a local untracked file (mode 0600). Never commit real secrets.
# Prefer ./install-validator.sh --master-url URL which generates this for you.
#
# Validators never run master. The generated validator.yaml sets
# agent.master_url = --master-url (Base master coordination API).
# Network public master (shipping default example):
#   --master-url https://chain.joinbase.ai
# Local disposable smoke/dev only (secondary):
#   --master-url http://127.0.0.1:3180
# (loopback is not the production default; verify /health is role=master).

COMPOSE_PROJECT_NAME=base-mission-validator

# Immutable validator runtime pin (repository@sha256:<64 hex>).
# Bare :latest is never a compose runtime selector; auto-update rewrites these.
BASE_VALIDATOR_IMAGE_REPOSITORY=ghcr.io/baseintelligence/base-validator-runtime
BASE_VALIDATOR_IMAGE_DIGEST=replace_with_64_lowercase_hex

# Host-side auto-update (install-validator enables a systemd timer by default).
BASE_VALIDATOR_TRACK_IMAGE=ghcr.io/baseintelligence/base-validator-runtime:latest
BASE_VALIDATOR_IMAGE_UPDATE_HOLD=0

# Host docker.sock access for the non-root agent (uid 1000). install-validator.sh
# detects the socket group via stat when BASE_DOCKER_GID is unset.
# Used by compose group_add so the container can open the mounted socket.
BASE_DOCKER_GID=987
# Optional override if the host socket is not at the default path:
# BASE_DOCKER_SOCKET=/var/run/docker.sock

# Host paths owned by this validator only.
BASE_VALIDATOR_CONFIG=/absolute/path/to/validator.yaml
# Real directory (not a host symlink with restrictive parents); mounted RO at
# /var/lib/base/identity. Container HOME is /var/lib/base/state (writable volume).
BASE_VALIDATOR_PROTOCOL_IDENTITY=/absolute/path/to/identity
BASE_VALIDATOR_BROKER_TOKEN=/absolute/path/to/broker_token
