"""Challenge weight computation."""

from __future__ import annotations

from sqlalchemy import func, select

from .db import database
from .models import Submission


async def get_weights() -> dict[str, float]:
    """Return raw hotkey weights for the Platform master to normalize."""

    statement = select(Submission.miner_hotkey, func.count(Submission.id)).group_by(
        Submission.miner_hotkey
    )
    async with database.session() as session:
        rows = (await session.execute(statement)).all()

    return {hotkey: float(count) for hotkey, count in rows}
